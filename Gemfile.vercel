source "https://rubygems.org"

# Jekyll 4.x is compatible with Ruby 3.3+
# Used for Vercel preview builds only; GitHub Pages uses the main Gemfile
gem "jekyll", "~> 4.3"
gem "jekyll-remote-theme"
gem "jekyll-sitemap"
gem "jekyll-mentions"
gem "jekyll-paginate"
gem "jekyll-seo-tag"
gem "jekyll-redirect-from"
gem "jekyll-default-layout"
gem "jekyll-feed"
gem "jemoji"
gem "webrick"
